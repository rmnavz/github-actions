# Sample .gitignore for a general project
# Ignore OS files
.DS_Store
Thumbs.db

# Ignore node modules and package lock if using Node.js
dist/
node_modules/
package-lock.json
yarn.lock

# Ignore Python cache if using Python
__pycache__/
*.pyc

# Ignore build and log files
*.log
*.tmp
*.bak
build/

# Ignore VSCode settings
.vscode/

# Ignore environment files
.env
.env.*

# Ignore coverage reports
coverage/
*.lcov

# Ignore other common files
*.swp
*.swo
